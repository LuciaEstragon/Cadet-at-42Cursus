        def __init__(self):
            super().__init__()  # ← inicializa _grow_calls
            self._shade_calls = 0
        
        def display(self):
            base = super().display()
            return f"{base}\nShade calls: {self._shade_calls}"
    
    def __init__(self, name):
        super().__init__(name)
        self._stats = self.Stats()  # ← usa Tree.Stats (no Plant.Stats)

# PARTE 5: EL EJERCICIO 6 COMPLETO EXPLICADO LÍNEA POR LÍNEA

## Lo que pide el enunciado (traducido)

> 1. Crear un método estático en Plant que compruebe si una edad es mayor de un año
> 2. Crear un método de clase en Plant que cree una planta "anónima"
> 3. Crear clase Seed que hereda de Flower, con contador de semillas
> 4. Cada planta tiene un sistema interno (clase anidada) para estadísticas
> 5. Trees necesitan estadística extra (llamadas a produce_shade)
> 6. Función independiente que muestre estadísticas de cualquier planta

## Código completo explicado

```python
# ============================================================
# PARTE A: Clase base Plant (con static y classmethod)
# ============================================================

class Plant:
    # ---------- CLASE ANIDADA (punto 4) ----------
    class Stats:
        """Sistema interno de estadísticas - encapsulado"""
        def __init__(self):
            self._grow_calls = 0
            self._age_calls = 0
            self._show_calls = 0
        
        def record_grow(self):
            self._grow_calls += 1
        
        def record_age(self):
            self._age_calls += 1
        
        def record_show(self):
            self._show_calls += 1
        
        def display(self) -> str:
            return f"Stats: {self._grow_calls} grow, {self._age_calls} age, {self._show_calls} show"
    
    # ---------- MÉTODO NORMAL ----------
    def __init__(self, name: str, height: float, age: int):
        self.name = name
        self.height = height
        self.age = age
        self._stats = self.Stats()  # ← instancia de la clase anidada
    
    # ---------- MÉTODOS NORMALES (registran estadísticas) ----------
    def grow(self, amount: float):
        self._stats.record_grow()   # ← registra automáticamente
        self.height += amount
    
    def age(self, days: int):
        self._stats.record_age()
        self.age += days
    
    def show(self) -> str:
        self._stats.record_show()
        return f"{self.name}: {self.height}cm, {self.age} days old"
    
    def get_stats(self) -> str:
        return self._stats.display()
    
    # ---------- MÉTODO ESTÁTICO (punto 1) ----------
    @staticmethod
    def is_older_than_year(age: int) -> bool:
        """NO usa self - solo opera con el parámetro que recibe"""
        return age > 365
    
    # ---------- MÉTODO DE CLASE (punto 2) ----------
    @classmethod
    def create_anonymous(cls) -> "Plant":
        """Usa cls (la clase) para crear una instancia"""
        return cls("Unknown plant", 0.0, 0)


# ============================================================
# PARTE B: Flower (hereda de Plant)
# ============================================================

class Flower(Plant):
    def __init__(self, name: str, height: float, age: int, color: str):
        super().__init__(name, height, age)
        self.color = color
        self._bloomed = False
    
    def bloom(self) -> str:
        self._bloomed = True
        return f"{self.name} is blooming beautifully!"
    
    def show(self) -> str:
        base = super().show()
        return f"{base}\nColor: {self.color}"


# ============================================================
# PARTE C: Tree (con estadística extra - punto 5)
# ============================================================

class Tree(Plant):
    # Heredamos la clase Stats y la extendemos
    class Stats(Plant.Stats):
        def __init__(self):
            super().__init__()
            self._shade_calls = 0
        
        def record_shade(self):
            self._shade_calls += 1
        
        def display(self) -> str:
            base = super().display()
            return f"{base}\n{self._shade_calls} shade"
    
    def __init__(self, name: str, height: float, age: int, trunk_diameter: float):
        super().__init__(name, height, age)
        self.trunk_diameter = trunk_diameter
        # ¡Importante! Reemplazamos _stats con nuestra versión extendida
        self._stats = self.Stats()
    
    def produce_shade(self) -> str:
        self._stats.record_shade()  # ← estadística EXTRA solo para árboles
        return f"Tree {self.name} now produces a shade of {self.height}cm long and {self.trunk_diameter}cm wide."
    
    def show(self) -> str:
        base = super().show()
        return f"{base}\nTrunk diameter: {self.trunk_diameter}cm"


# ============================================================
# PARTE D: Seed (hereda de Flower - punto 3)
# ============================================================

class Seed(Flower):
    def __init__(self, name: str, height: float, age: int, color: str, seeds: int = 0):
        super().__init__(name, height, age, color)
        self.seeds = seeds
    
    def bloom(self) -> str:
        super().bloom()  # ← llama bloom() de Flower
        self.seeds = 42  # ← al bloomar, produce semillas
        return f"{self.name} is blooming beautifully!"
    
    def show(self) -> str:
        base = super().show()
        return f"{base}\nSeeds: {self.seeds}"


# ============================================================
# PARTE E: Función independiente (punto 6)
# ============================================================

def display_plant_stats(plant: Plant) -> None:
    """POLIMORFISMO - funciona con Plant, Flower, Tree, Seed"""
    print(f"[statistics for {plant.name}]")
    print(plant.get_stats())
```

